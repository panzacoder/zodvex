{
  "name": "convex-auto-optimistic",
  "version": "0.0.0",
  "private": true,
  "description": "Automatic optimistic updates for Convex mutations, driven by a table-dependency graph.",
  "keywords": ["convex", "optimistic-updates", "react"],
  "license": "MIT",
  "author": "Jake Hebert",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    }
  },
  "files": ["dist", "src", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "bun x biome check src __tests__",
    "lint:fix": "bun x biome check --write src __tests__",
    "format": "bun x biome format --write src __tests__"
  },
  "peerDependencies": {
    "convex": "^1.28.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.6",
    "@types/node": "^24.8.0",
    "@types/react": "^19.0.0",
    "convex": "^1.28.0",
    "react": "^19.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
