{
  "name": "zodvex",
  "version": "0.7.1-beta.5",
  "description": "Codec-first Zod v4 integration for Convex -- type-safe validation, encoding, DB wrapping, and codegen.",
  "keywords": ["zod", "convex", "validators", "codec", "mapping", "schema", "validation"],
  "homepage": "https://github.com/panzacoder/zodvex#readme",
  "bugs": {
    "url": "https://github.com/panzacoder/zodvex/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/panzacoder/zodvex.git"
  },
  "license": "MIT",
  "author": "Jake Hebert",
  "type": "module",
  "bin": {
    "zodvex": "./dist/cli/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js",
      "default": "./dist/core/index.js"
    },
    "./mini": {
      "types": "./dist/mini/index.d.ts",
      "import": "./dist/mini/index.js",
      "default": "./dist/mini/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js",
      "default": "./dist/server/index.js"
    },
    "./codegen": {
      "types": "./dist/codegen/index.d.ts",
      "import": "./dist/codegen/index.js",
      "default": "./dist/codegen/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js",
      "default": "./dist/react/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js",
      "default": "./dist/client/index.js"
    },
    "./form/mantine": {
      "types": "./dist/form/mantine/index.d.ts",
      "import": "./dist/form/mantine/index.js",
      "default": "./dist/form/mantine/index.js"
    },
    "./labs": {
      "types": "./dist/labs/index.d.ts",
      "import": "./dist/labs/index.js",
      "default": "./dist/labs/index.js"
    }
  },
  "files": ["dist", "src", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly",
    "dev": "bun run tsup --watch",
    "type-check": "bun run tsc -p tsconfig.typecheck.json",
    "test": "vitest run",
    "lint": "bun x biome check src __tests__",
    "lint:fix": "bun x biome check --write src __tests__",
    "format": "bun x biome format --write src __tests__",
    "prepare": "tsup && tsc --emitDeclarationOnly",
    "prepublishOnly": "bun run type-check"
  },
  "peerDependencies": {
    "convex": "^1.28.0",
    "convex-helpers": "^0.1.104",
    "react": "^18.0.0 || ^19.0.0",
    "zod": "^4.3.6"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "dependencies": {
    "tinyglobby": "^0.2.15",
    "ts-morph": "^25.0.0"
  },
  "devDependencies": {
    "zod-to-mini": "workspace:*",
    "@biomejs/biome": "^2.2.6",
    "@types/bun": "^1.3.0",
    "@types/node": "^24.8.0",
    "ai": "^6.0.6",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=20",
    "bun": ">=1.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
