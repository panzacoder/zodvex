{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "preserveSymlinks": true,
    "types": ["bun-types", "vite/client"],
    "outDir": "dist",
    "declaration": true,
    "paths": {}
  },
  "include": ["src", "convex"],
  "exclude": ["convex/**/*.test.ts"]
}
